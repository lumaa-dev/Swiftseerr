    "settings.notifications.seerrapn" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[SeerrAPN](https://github.com/lumaa-dev/SeerrAPN) ist ein selbst hostbarer Benachrichtigungsdienst, mit dem Webhook-Benachrichtigungen über Swiftseerr an Ihr Gerät gesendet werden können."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[SeerrAPN](https://github.com/lumaa-dev/SeerrAPN) is a self-hostable notification service to send webhook notifications to your device through Swiftseerr."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[SeerrAPN](https://github.com/lumaa-dev/SeerrAPN) es un servicio de notificaciones autoalojable para enviar notificaciones webhook a tu dispositivo mediante Swiftseerr."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[SeerrAPN](https://github.com/lumaa-dev/SeerrAPN) est un service de notification auto-hébergeable pour envoyer des notifications webhook vers votre appareil grâce à Swiftseerr. "
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[SeerrAPN](https://github.com/lumaa-dev/SeerrAPN) は、Swiftseerrを通じてWebhook通知をデバイスに送信するためのセルフホスト可能な通知サービスです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[SeerrAPN](https://github.com/lumaa-dev/SeerrAPN)은 Swiftseerr를 통해 기기로 웹훅 알림을 보내는 자체 호스팅 가능한 알림 서비스입니다."
          }
        }
      }
    },
