    "def-age.footer" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Sie einen Film oder eine Serie mit Altersbeschränkung ansehen, werden Sie aufgefordert, Ihre Altersgruppe zu bestätigen. Swiftseerr kennt weder Ihr Geburtsdatum noch Ihr genaues Alter."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When viewing a movie or TV show with an age limit, you will be prompted to confirm your age range. Swiftseerr doesn’t know your birthday or your exact age."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al ver una película o serie con límite de edad, se te pedirá que confirmes tu rango de edad. Swiftseerr no conoce tu fecha de nacimiento ni tu edad exacta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lors du visionnage d’un film ou d’une série avec une limite d’âge, il vous sera demandé de confirmer votre tranche d’âge. Swiftseerr ne connaît ni votre date de naissance ni votre âge exact."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "年齢制限のある映画やテレビ番組を表示するときは、年齢層の確認を求められます。Swiftseerrはあなたの誕生日や正確な年齢を把握しません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "연령 제한이 있는 영화나 TV 프로그램을 볼 때 연령대를 확인하라는 메시지가 표시됩니다. Swiftseerr는 생일이나 정확한 나이를 알지 못합니다."
          }
        }
      }
    },
