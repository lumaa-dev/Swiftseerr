    "onboarding.welcome" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Willkommen bei Swiftseerr! Der native, quelloffene und kostenlose Seerr-Client. Mit Swiftseerr können Sie alles tun, was auf Seerr möglich ist, aber direkt auf Ihrem Gerät!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Welcome to Swiftseerr! The native, open-source and free Seerr client. Swiftseerr allows you to do everything that’s possible on Seerr but on your device!"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¡Bienvenido a Swiftseerr! El cliente Seerr nativo, de código abierto y gratuito. Swiftseerr te permite hacer todo lo que es posible en Seerr, pero en tu dispositivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bienvenue sur Swiftseer ! Le client Seerr natif, open-source et gratuit. Swiftseerr vous permet de faire tout ce qui est déjà possible sur Seerr mais sur votre appareil !"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Swiftseerrへようこそ！ネイティブでオープンソース、無料のSeerrクライアントです。Swiftseerrを使うと、Seerrでできることをあなたのデバイス上で実行できます！"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Swiftseerr에 오신 것을 환영합니다! 네이티브 오픈 소스 무료 Seerr 클라이언트입니다. Swiftseerr를 사용하면 Seerr에서 가능한 모든 작업을 기기에서 할 수 있습니다!"
          }
        }
      }
    },
